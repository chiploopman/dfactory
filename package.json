{
  "name": "dfactory",
  "private": true,
  "version": "0.1.0",
  "description": "Framework-agnostic PDF document designer, catalog, and generation platform.",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm build && node packages/cli/dist/index.js dev --config dfactory.config.vue.ts",
    "serve": "pnpm build && node packages/cli/dist/index.js serve --config dfactory.config.ts",
    "index": "pnpm build && node packages/cli/dist/index.js index --config dfactory.config.ts",
    "doctor": "pnpm build && node packages/cli/dist/index.js doctor --config dfactory.config.ts",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:licenses": "vitest run tests/unit/pdf-feature-license-policy.test.ts",
    "test:e2e": "pnpm build && playwright test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.3.0",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "@dfactory/cli": "workspace:*",
    "@dfactory/core": "workspace:*",
    "@dfactory/framework-react": "workspace:*",
    "@dfactory/framework-vue": "workspace:*",
    "@dfactory/pdf-feature-pagedjs": "workspace:*",
    "@dfactory/pdf-feature-pdf-lib": "workspace:*",
    "@dfactory/pdf-feature-standard": "workspace:*",
    "@dfactory/module-loader-bundle": "workspace:*",
    "@dfactory/module-loader-vite": "workspace:*",
    "@dfactory/server": "workspace:*",
    "@dfactory/renderer-playwright": "workspace:*",
    "@dfactory/template-kit": "workspace:*",
    "@dfactory/ui": "workspace:*",
    "istextorbinary": "^9.5.0"
  }
}
