{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "tsconfig.base.json",
    "tsconfig.workspace.base.json",
    "tsconfig.typecheck.base.json",
    "tsdown/**"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".dfactory/**"]
    },
    "docs:build": {
      "dependsOn": ["^docs:build"],
      "outputs": ["apps/docs/.next/**", "apps/docs/.source/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "docs:dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "docs:lint": {
      "dependsOn": ["^docs:lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "docs:typecheck": {
      "dependsOn": ["^docs:typecheck"],
      "outputs": []
    },
    "docs:sync-openapi": {
      "dependsOn": ["^build"],
      "outputs": ["apps/docs/content/openapi/dfactory.openapi.json"]
    },
    "docs:check-openapi-sync": {
      "outputs": []
    },
    "docs:check-links": {
      "outputs": []
    },
    "docs:validate-frontmatter": {
      "outputs": []
    },
    "docs:check-readmes": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
