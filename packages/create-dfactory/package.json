{
  "name": "create-dfactory",
  "version": "0.1.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiploopman/dfactory.git"
  },
  "homepage": "https://github.com/chiploopman/dfactory#readme",
  "bugs": {
    "url": "https://github.com/chiploopman/dfactory/issues"
  },
  "keywords": [
    "dfactory",
    "pdf",
    "templates",
    "scaffold"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "create-dfactory": "bin/create-dfactory.cjs"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "pnpm run build",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "tsx": "^4.20.5"
  }
}
