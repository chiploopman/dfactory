{
  "name": "create-dfactory",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiploopman/dfactory.git"
  },
  "homepage": "https://github.com/chiploopman/dfactory#readme",
  "bugs": {
    "url": "https://github.com/chiploopman/dfactory/issues"
  },
  "keywords": ["dfactory", "pdf", "templates", "scaffold"],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "create-dfactory": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepack": "pnpm run build",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.20.5"
  }
}
