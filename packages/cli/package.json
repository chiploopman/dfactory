{
  "name": "@dfactory/cli",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiploopman/dfactory.git"
  },
  "homepage": "https://github.com/chiploopman/dfactory#readme",
  "bugs": {
    "url": "https://github.com/chiploopman/dfactory/issues"
  },
  "keywords": ["dfactory", "pdf", "templates", "cli"],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "dfactory": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "pnpm run build",
    "dev": "tsx src/index.ts dev",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist",
    "serve": "tsx src/index.ts serve",
    "index": "tsx src/index.ts index",
    "doctor": "tsx src/index.ts doctor"
  },
  "dependencies": {
    "@dfactory/core": "workspace:*",
    "@dfactory/renderer-playwright": "workspace:*",
    "@dfactory/server": "workspace:*",
    "@dfactory/ui": "workspace:*",
    "commander": "^14.0.1",
    "playwright": "^1.54.2"
  },
  "devDependencies": {
    "tsx": "^4.20.5"
  }
}
