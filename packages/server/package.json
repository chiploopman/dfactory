{
  "name": "@dfactory/server",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiploopman/dfactory.git"
  },
  "homepage": "https://github.com/chiploopman/dfactory#readme",
  "bugs": {
    "url": "https://github.com/chiploopman/dfactory/issues"
  },
  "keywords": ["dfactory", "pdf", "templates"],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dfactory/core": "workspace:*",
    "@dfactory/pdf-feature-standard": "workspace:*",
    "@dfactory/renderer-playwright": "workspace:*",
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.2.0",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "fastify": "^5.6.0",
    "chokidar": "^4.0.3",
    "zod": "^4.1.11",
    "bundle-require": "^5.1.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  }
}
