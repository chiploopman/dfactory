{
  "name": "@dfactory/pdf-primitives-react",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dfactory/pdf-primitives-core": "workspace:*",
    "react": "^19.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.13",
    "tsup": "^8.3.5"
  }
}
