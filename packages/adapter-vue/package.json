{
  "name": "@dfactory/framework-vue",
  "version": "0.1.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiploopman/dfactory.git"
  },
  "homepage": "https://github.com/chiploopman/dfactory#readme",
  "bugs": {
    "url": "https://github.com/chiploopman/dfactory/issues"
  },
  "keywords": [
    "dfactory",
    "pdf",
    "templates"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dfactory/core": "workspace:*",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/server-renderer": "^3.5.21",
    "vue": "^3.5.21"
  }
}
